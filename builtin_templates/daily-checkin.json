{
  "id": "daily-checkin",
  "name": "交易所每日签到",
  "description": "示例：登录后访问任务页，点击签到并提取结果文案。",
  "config": {
    "meta": {
      "name": "交易所每日签到",
      "description": "登录站点后进入活动页执行签到并保存提示文案"
    },
    "global": {
      "timeout": 30,
      "retryTimes": 3,
      "randomDelay": true,
      "headless": false,
      "outputDirectory": ""
    },
    "login": {
      "method": "password",
      "url": "https://example.com/login",
      "usernameSelector": "#email",
      "passwordSelector": "#password",
      "submitSelector": "button[type='submit']",
      "successSelector": ".dashboard",
      "username": "{{env('CHECKIN_USERNAME')}}",
      "password": "{{env('CHECKIN_PASSWORD')}}",
      "captchaEnabled": false,
      "captchaSelector": "",
      "captchaMode": "manual"
    },
    "proxy": {
      "enabled": false,
      "type": "http",
      "mode": "single",
      "single": "",
      "list": [],
      "rotation": "sequential"
    },
    "tasks": [
      {
        "id": "navigate-1",
        "type": "navigate",
        "label": "打开活动页",
        "url": "https://example.com/tasks",
        "waitUntil": "load"
      },
      {
        "id": "click-1",
        "type": "click",
        "label": "点击签到",
        "selector": ".checkin-button",
        "timeout": 30,
        "index": 0
      },
      {
        "id": "wait-1",
        "type": "wait",
        "label": "等待成功提示",
        "mode": "selector",
        "durationSeconds": 2,
        "selector": ".toast-success",
        "timeout": 20
      },
      {
        "id": "extract-1",
        "type": "extract",
        "label": "提取提示内容",
        "selector": ".toast-success",
        "attribute": "text",
        "variable": "checkin_message"
      }
    ]
  }
}
