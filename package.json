{
  "name": "script-generator-desktop",
  "version": "0.1.4",
  "description": "零代码可视化脚本生成器桌面应用",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "马到成功",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "release:github": "powershell -ExecutionPolicy Bypass -File scripts/publish_release.ps1",
    "publish:release": "npm run dist && npm run release:github",
    "setup:python": "python -m pip install -r python_engine/requirements-dev.txt",
    "package:engine": "python scripts/build_engine.py"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@reduxjs/toolkit": "^2.9.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "antd": "^5.28.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^38.7.1",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.ranjing666.scriptgenerator",
    "productName": "脚本生成器",
    "directories": {
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python_engine",
        "to": "python_engine",
        "filter": [
          "**/*",
          "!__pycache__",
          "!*.pyc"
        ]
      },
      {
        "from": "builtin_templates",
        "to": "builtin_templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
